// VibeCheck Security SaaS - Prisma Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  name          String?
  role          Role     @default(USER)
  credits       Int      @default(5) // 5 free scans
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organizations Organization[]
  repos         Repository[]
  shieldLogs    ShieldLog[]
  apiKeys       ApiKey[]
  scanHistory   AuditReport[]
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  createdAt DateTime @default(now())
}

model Repository {
  id        String   @id @default(cuid())
  name      String
  gitUrl    String
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  status    String   @default("connected")
  lastScan  DateTime?
  
  audits    AuditReport[] @relation("RepoAudits")
  createdAt DateTime @default(now())
}

model AuditReport {
  id            String   @id @default(cuid())
  repoId        String?
  repo          Repository? @relation("RepoAudits", fields: [repoId], references: [id])
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  repoUrl       String
  issuesFound   Int
  criticalFound Int
  fullJson      String
  createdAt     DateTime @default(now())
}

model ShieldLog {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  promptPreview   String
  riskScore       Int
  status          String
  ruleMatched     String?
  createdAt       DateTime @default(now())
}

model ApiKey {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  name      String
  key       String   @unique
  lastUsed  DateTime?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}
